# 亲健后端环境变量
# 用于本地直接运行 FastAPI 时复制为 backend/.env

SECRET_KEY=your-secret-key-change-me
DATABASE_URL=postgresql+psycopg://qinjian:qinjian@localhost:5432/qinjian
FRONTEND_ORIGIN=https://your-domain.com
APP_TIMEZONE=Asia/Shanghai

# 通用 OpenAI 兼容网关（推荐）
AI_API_KEY=
AI_BASE_URL=
AGENT_SESSION_TTL_HOURS=12
AGENT_CHAT_HISTORY_LIMIT=8
ASR_PROVIDER=qwen3
OPENAI_COMPATIBLE_ASR_MODEL=whisper-1
REALTIME_ASR_PROVIDER=qwen3
REALTIME_ASR_TICKET_EXPIRE_SECONDS=120
REALTIME_ASR_MAX_SESSION_SECONDS=60
REALTIME_ASR_STOP_TIMEOUT_SECONDS=20

# 硅基流动 API（兼容旧配置）
SILICONFLOW_API_KEY=<SILICONFLOW_API_KEY>
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Qwen3 ASR（百炼 / DashScope）
QWEN_ASR_API_KEY=
QWEN_ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_ASR_FILE_MODEL=qwen3-asr-flash
QWEN_ASR_REALTIME_MODEL=qwen3-asr-flash-realtime
XFYUN_RTASR_APP_ID=
XFYUN_RTASR_API_KEY=
XFYUN_RTASR_API_SECRET=
XFYUN_RTASR_WS_URL=wss://office-api-ast-dx.iflyaisol.com/ast/communicate/v1
XFYUN_RTASR_LANG=autodialect

# AI 模型（默认值与 docker-compose.yml / README 保持一致）
AI_MULTIMODAL_MODEL=moonshot/kimi-k2.6
AI_TEXT_MODEL=Pro/deepseek-ai/DeepSeek-V3.2

# 手机验证码与登录风控存储（生产建议 Redis）
PHONE_CODE_STORE=redis
REDIS_URL=redis://localhost:6379/0
PHONE_CODE_REDIS_PREFIX=qinjian:phone-code:
REQUEST_COOLDOWN_REDIS_PREFIX=qinjian:request-cooldown:
REQUEST_COOLDOWN_REDIS_TIMEOUT_SECONDS=0.5
