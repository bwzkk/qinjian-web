# 亲健 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ⚠️ 永远不要将 .env 文件提交到 Git！

# === 数据库配置 ===
DB_PASSWORD=your_secure_password_here

# === 应用密钥 ===
# 用于 JWT 签名，请使用随机生成的长字符串
SECRET_KEY=your_random_secret_key_min_32_chars

# === 硅基流动 AI API ===
# 从 https://siliconflow.cn 获取
SILICONFLOW_API_KEY=sk-your_siliconflow_api_key_here

# === 通用 OpenAI 兼容模型网关（可选，用它时可不填 SiliconFlow）===
AI_API_KEY=
AI_BASE_URL=

# === 微信小程序（可选）===
# 如需微信登录功能，从微信小程序后台获取
WECHAT_APPID=wx_optional_your_appid
WECHAT_SECRET=optional_your_secret

# === AI 模型配置（可选，使用默认值即可）===
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
AI_MULTIMODAL_MODEL=moonshot/kimi-k2.5
AI_TEXT_MODEL=deepseek-ai/DeepSeek-V3

# === 手机验证码存储（可选，默认 memory）===
PHONE_CODE_STORE=memory
REDIS_URL=redis://localhost:6379/0
PHONE_CODE_REDIS_PREFIX=qinjian:phone-code:
